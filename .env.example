# MySQL (production / docker-compose)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=quality_analyzer
MYSQL_USER=wqa
MYSQL_PASSWORD=wqa_secret

# Gemini AI (optional — fallback recommendations work without it)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-3.1-flash-lite

# Crawler limits
CRAWL_MAX_PAGES=50
CRAWL_MAX_DEPTH=5
CRAWL_TIMEOUT_MS=10000

# Server
PORT=8080
SPRING_PROFILES_ACTIVE=dev
